# Backend OpenData AI da interrogare via A2A (default se non passi un URL nella UI).
# In locale (stack docker): http://localhost:8000  — oppure l'host esposto.
A2A_BACKEND_URL=http://localhost:8000

# Token di default usato dal proxy se non ne inserisci uno nella UI (opzionale).
# JWT Clerk o API key programmatica (od_…). Se il backend gira con
# AUTH_ENABLED=false puoi lasciarlo vuoto.
# A2A_BEARER=

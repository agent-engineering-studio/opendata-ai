# ─────────────────────────────────────────────────────────────────
#  Production deploy — copy to `.env.production` (gitignored).
#
#  Two supported variants — pick ONE:
#    A) LLM_PROVIDER=claude         → Anthropic Claude API (default here).
#                                     Cheapest path to ship; needs ANTHROPIC_API_KEY only.
#    B) LLM_PROVIDER=azure_foundry  → Azure AI Foundry Agent Service.
#                                     Entra-ID auth via DefaultAzureCredential.
#                                     Needed for Azure Container Apps deploys.
#
#  Ollama is NOT used in production. Leave OLLAMA_* unset.
# ─────────────────────────────────────────────────────────────────

# ── Ports (in cloud these are container ports — the platform maps them) ──
CKAN_MCP_PORT=8080
ISTAT_MCP_PORT=8081
OPENCOESIONE_MCP_PORT=8082
BACKEND_PORT=8000

# ── Data sources ──
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
CKAN_HTTP_TIMEOUT=30
ISTAT_SDMX_BASE_URL=https://esploradati.istat.it/SDMXWS/rest
ISTAT_HTTP_TIMEOUT=60
OPENCOESIONE_BASE_URL=https://opencoesione.gov.it/it/api
OPENCOESIONE_HTTP_TIMEOUT=60
EUROSTAT_SDMX_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/sdmx/2.1
OECD_SDMX_BASE_URL=https://sdmx.oecd.org/public/rest

# All four sources ON in production — the whole point of going to claude/foundry
# is to spend the LLM budget on coverage rather than on local debug speed.
ENABLE_CKAN=true
ENABLE_ISTAT=true
ENABLE_EUROSTAT=true
ENABLE_OECD=true
ENABLE_OPENCOESIONE=true
OPENCOESIONE_AGENT_NAME=opencoesione
ENABLE_OSM=true
OSM_AGENT_NAME=osm
ENABLE_ISPRA=true
ISPRA_MCP_URL=http://ispra-mcp:8083/mcp
ISPRA_AGENT_NAME=ispra
# Knowledge Graph: deployment esterno — abilitare solo quando il kg-mcp è
# raggiungibile in streamable-http e i documenti del comune sono ingeriti.
ENABLE_KG=false
KG_MCP_URL=
KG_AGENT_NAME=kg
KG_NAMESPACE_PREFIX=comune-
KG_UI_URL=
# Mirror locale del bulk OpenCoesione (aggregati pesanti + generatori della
# modalità Idee). Riusa il Neon DSN (read-only dal punto di vista dell'MCP
# server); popolato con `make oc-sync OC_SYNC_ARGS="--regione PUG"` +
# `make comuni-sync` (sync periodico consigliato: mensile).
OPENCOESIONE_DB_URL=

# ── Scoping mono-regione: il verticale di PRODUZIONE è focalizzato sulla
# PUGLIA. REGION (codice ISTAT regione, 2 cifre) è la sorgente di verità: da
# esso si derivano province, portale CKAN, oc_cod_regione e fq via
# config_data/regioni.yaml. Puglia = 16.
REGION=16

# Ambito territoriale LEGACY (usato solo quando REGION è vuoto): autocomplete,
# zone e /programma rifiutano comuni fuori da queste province (FG, BA, TA, BR,
# LE, BAT). Con REGION=16 le province derivano da regioni.yaml.
TERRITORIO_PROVINCE=071,072,073,074,075,110

# OSM maps for GeoJSON resources (no LLM cost — deterministic Leaflet render)
OSM_MCP_URL=http://osm-mcp:8080/mcp
ENABLE_OSM_MAPS=true

# ═════════════════════════════════════════════════════════════════
# ── Provider selection ───────────────────────────────────────────
# ═════════════════════════════════════════════════════════════════
# "auto" resolves by credential presence: claude (if ANTHROPIC_API_KEY) →
# azure_foundry (if Azure project set) → ollama_cloud (if OLLAMA_CLOUD_API_KEY)
# → ollama (local). Claude wins over Ollama Cloud when both keys are set. Set
# the key(s) below and auto picks the right provider; a user's own BYOK key
# overrides it. Force explicitly: claude | ollama_cloud | azure_foundry | ollama.
LLM_PROVIDER=auto

# ── Variant A: Anthropic Claude (recommended; auto picks this when key set) ──
# Required — store as a secret in your platform (not in this file once filled).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Options: claude-sonnet-4-6 (balanced), claude-opus-4-7 (smartest),
#          claude-haiku-4-5 (fastest/cheapest).
CLAUDE_MODEL=claude-sonnet-4-6

# ── BYOK (bring your own key) ────────────────────────────────────
# Users can run analyses on THEIR OWN LLM key (Claude / Ollama Cloud /
# Ollama local) instead of a subscription. Their keys are encrypted at rest
# with this Fernet key — generate one with `opendata-byok-keygen` and keep it
# secret + stable (rotating it invalidates every stored key). REQUIRED for the
# /account/llm-key endpoints; without it they fail closed.
BYOK_ENCRYPTION_KEY=
# Ollama Cloud endpoint + default model (model TBD). Set OLLAMA_CLOUD_API_KEY to
# use Ollama Cloud as the SYSTEM provider (auto picks it when no Claude key);
# leave empty → ollama_cloud is BYOK-only.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# ═════════════════════════════════════════════════════════════════
# ── Variant B: Azure AI Foundry (uncomment to use) ───────────────
# ═════════════════════════════════════════════════════════════════
# LLM_PROVIDER=azure_foundry
#
# Endpoint format: https://<hub>.services.ai.azure.com/api/projects/<project>
# Resource ID:     /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<hub>/projects/<project>
# AZURE_AI_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>
# AZURE_AI_PROJECT_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<hub>/projects/<project>
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5
#
# Auth is via DefaultAzureCredential — no API key here. Make sure the
# Container App's managed identity has the right Foundry role.

# ── MCP server URLs ──
# Container-internal hostnames (override per platform: in Azure Container Apps
# these become the ACA-assigned FQDNs of each app).
CKAN_MCP_URL=http://ckan-mcp:8080/mcp
ISTAT_MCP_URL=http://istat-mcp:8081/mcp
OPENCOESIONE_MCP_URL=http://opencoesione-mcp:8082/mcp

# ── Postgres (REQUIRED — Neon serverless) ──
# Paste the Neon "Pooler" connection string verbatim. The backend strips
# `sslmode`/`channel_binding` and routes them to asyncpg `connect_args`;
# Alembic gets the same DSN rewritten to `postgresql+psycopg://`.
# Get it from: Neon console → Connection details → Pooled connection.
DATABASE_URL=postgresql://neondb_owner:CHANGE_ME@ep-xxxxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Redis (REQUIRED — point at your self-hosted Aruba Redis 7, logical db 1) ──
REDIS_URL=redis://:CHANGE_ME@redis.opendata.<your-domain>:6379/1
RATE_LIMIT_PER_MINUTE=60
# Per-tier overrides as `tier=limit` (comma-separated); names must match the
# user's `subscription_tier`. Unlisted/"free" → baseline above. Use a large
# number (not 0) for an "unlimited" tier — 0 disables the limiter for that tier.
RATE_LIMIT_TIERS=pro=300,enterprise=1200

# ── Frontend bundle config (baked into the static export at build time) ──
NEXT_PUBLIC_API_URL=https://api.opendata.<your-domain>
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME_USE_REAL_ENV
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Backend CORS — frontend origin lives on GitHub Pages ──
CORS_ALLOW_ORIGINS=https://opendata.<your-domain>

# ── A2A protocol (Agent-to-Agent) ──
# Public AgentCard at /.well-known/agent.json. JSON-RPC mounted at /a2a/.
A2A_ENABLED=true
A2A_PUBLIC_URL=https://api.opendata.<your-domain>
# Outbound A2A specialist — leave empty unless you want to fan out to a
# remote A2A peer as part of every query. Bearer is forwarded as-is.
# A2A_SPECIALIST_URL=
# A2A_SPECIALIST_BEARER=
# A2A_SPECIALIST_NAME=external

# ── Auth OIDC (REQUIRED in production) ──
# Standard OIDC/JWKS verification — any compliant IdP. Self-host Keycloak/
# Authentik (consigliato per un ente pubblico) e imposta l'issuer:
AUTH_ENABLED=true
OIDC_ISSUER=https://sso.<your-domain>/realms/opendata
# Imposta l'audience se il tuo IdP la emette (Keycloak sì, Clerk no):
OIDC_AUDIENCE=opendata-backend
# RBAC (#235): email promossa ad `admin` al primo accesso (primo amministratore
# che poi assegna i ruoli dalla dashboard admin). Ruoli nel nostro DB.
BOOTSTRAP_ADMIN_EMAIL=rtd@regione.example
#
# In alternativa, con Clerk (app app_3EMALiLi0UTULl89JPMKtaLENoy, .clerk/config.md):
# OIDC_ISSUER=https://clerk.<your-domain>   (o CLERK_JWT_ISSUER, alias legacy)
# CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME_USE_REAL_ENV
# CLERK_SECRET_KEY=sk_live_REPLACE_ME_USE_REAL_ENV     (platform secret)
# CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx (platform secret)

# ── Rate limit (protezione) ──
# Per-IP/globale come middleware prima dell'auth (protegge anche il pubblico).
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_IP_PER_MINUTE=120
RATE_LIMIT_GLOBAL_PER_MINUTE=0

# ── Stripe contributi (pagina /sostieni) ──
# Signing secret dell'endpoint webhook: Dashboard → Developers → Webhooks →
# (endpoint che punta a https://<backend>/webhooks/stripe) → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Restricted API key (rk_live_…), opzionale: serve solo se il webhook dovrà
# richiamare Stripe (es. retrieve subscription). Least-privilege.
# STRIPE_API_KEY=rk_live_REPLACE_ME_USE_REAL_ENV
# Mappa price→tier (account agentengineering, LIVE): collega i prezzi creati
# ai tier letti da subscription_tier / rate_limit_tiers.
STRIPE_PRICE_TIERS=price_1Tk8hlJTWGUeNFIfEKKbvHAV=sostenitore,price_1Tk8hmJTWGUeNFIfShzmBade=pro,price_1Tk8hnJTWGUeNFIffIrW5hnM=team

# ── Misc ──
LOG_LEVEL=INFO

# ═════════════════════════════════════════════════════════════════
# ── Azure-only: deploy inputs for infra/scripts/deploy.{sh,ps1} ──
# ═════════════════════════════════════════════════════════════════
# Only needed when variant B (azure_foundry) is active AND you're deploying
# to Azure Container Apps. Otherwise leave these unset.
#
# AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
# AZURE_RESOURCE_GROUP=rg-opendata-ai-prod
# AZURE_LOCATION=westeurope
# AZURE_ENV_NAME=prod
# ACR_NAME=opendataaiprod
# GITHUB_ORG=agent-engineering-studio
# GITHUB_REPO=opendata-ai

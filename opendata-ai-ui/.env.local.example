# URL of the opendata-orchestrator HTTP API (fan-out CKAN + ISTAT)
# - dev (host):     http://localhost:8000
# - compose:        http://opendata-orchestrator:8000
AGENT_API_URL=http://localhost:8000

# Regione monitorata da QUESTA installazione (una regione per deployment, #191).
# Mostra un titolo esplicativo globale "Cruscotto Open Data · Regione <nome>".
# Deve coincidere con REGION del backend. Vuoto = nessun titolo (dev/non-scoped).
# NEXT_PUBLIC_REGION_NAME=Puglia

# Auth OIDC (Fase 6): login/registrazione via il tuo IdP (Keycloak — SPID +
# email-OTP), Authorization-Code + PKCE lato browser. Vuoto = modalità dev senza
# auth. Deve puntare allo stesso issuer di OIDC_ISSUER del backend.
# NEXT_PUBLIC_OIDC_AUTHORITY=https://sso.regione.example/realms/opendata
# NEXT_PUBLIC_OIDC_CLIENT_ID=opendata-ui
# NEXT_PUBLIC_OIDC_SCOPE=openid profile email

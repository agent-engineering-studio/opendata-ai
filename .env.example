# ─────────────────────────────────────────────────────────────────
#  Local stack (.env) — copy this file to .env before `make up`.
# ─────────────────────────────────────────────────────────────────

# ── Ports exposed on the host ──
OLLAMA_PORT=11434
MCP_PORT=8080
AGENT_PORT=8002

# ── CKAN ──
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata

# ── LLM provider (ollama | openai | azure_openai) ──
LLM_PROVIDER=ollama

# ── Ollama ──
OLLAMA_BASE_URL=http://ckan-ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b

# ── OpenAI (only if LLM_PROVIDER=openai) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI (only if LLM_PROVIDER=azure_openai) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Misc ──
MCP_SERVER_URL=http://ckan-mcp:8080/mcp
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────
#  Local stack (.env) — copy this file to .env before `make up`.
# ─────────────────────────────────────────────────────────────────

# ── Ports exposed on the host ──
OLLAMA_PORT=11434
MCP_PORT=8080
AGENT_PORT=8002

# ── CKAN ──
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
CKAN_HTTP_TIMEOUT=30

# ── LLM provider ──
# Supported values:
#   ollama        → local model via Ollama (default, no API key required)
#                   Set OLLAMA_BASE_URL / OLLAMA_LLM_MODEL below.
#   azure_foundry → Azure AI Foundry Agent Service, Entra-ID authenticated
#                   Requires AZURE_AI_PROJECT_ENDPOINT and AZURE_AI_MODEL_DEPLOYMENT_NAME.
#   claude        → Anthropic Claude API
#                   Requires ANTHROPIC_API_KEY; model configurable via CLAUDE_MODEL.
LLM_PROVIDER=ollama

# ── Ollama ──
# OLLAMA_IMAGE: pre-built Docker image with the model already baked in.
#   - default: ghcr.io/agent-engineering-studio/ckan-mcp-ollama:latest (~7 GB)
#   - local build: leave OLLAMA_IMAGE unset (or as default) and run `make refresh-ollama`
#                  with OLLAMA_PULL_POLICY=if_not_present so Docker uses the local image
#   - fallback (pull at runtime): OLLAMA_IMAGE=ollama/ollama:latest + `make pull-models`
OLLAMA_IMAGE=ghcr.io/agent-engineering-studio/ckan-mcp-ollama:latest

# OLLAMA_PULL_POLICY: when does Docker pull from the registry?
#   - always (default in compose): pulls every `up` — safest for production but
#     overwrites a locally-built image. Set this to `if_not_present` if you have
#     just run `make build-ollama` / `make refresh-ollama` so the local image is kept.
OLLAMA_PULL_POLICY=if_not_present

OLLAMA_BASE_URL=http://ckan-ollama:11434

# Must match the MODEL_TAG built into the Ollama image (see Makefile OLLAMA_MODEL).
# The image bakes a custom modelfile (e.g. qwen2.5:16k) on top of the base
# (e.g. qwen2.5:7b-instruct) with PARAMETER num_ctx 16384 — use the custom name here,
# not the base name, otherwise Ollama will report "model not found".
OLLAMA_LLM_MODEL=qwen2.5:16k
OLLAMA_NUM_CTX=16384

# ── Anthropic Claude (only when LLM_PROVIDER=claude) ──
# Get an API key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# Defaults to claude-sonnet-4-6. Other options: claude-opus-4-7, claude-haiku-4-5-20251001.
# CLAUDE_MODEL=claude-sonnet-4-6

# ── MCP server URL the agent container dials (compose-internal) ──
MCP_SERVER_URL=http://ckan-mcp:8080/mcp

# ── Misc ──
LOG_LEVEL=INFO

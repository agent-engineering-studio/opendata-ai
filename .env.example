# ─────────────────────────────────────────────────────────────────
#  Local stack (.env) — copy this file to .env before `make up`.
# ─────────────────────────────────────────────────────────────────

# ── Ports exposed on the host ──
OLLAMA_PORT=11434
MCP_PORT=8080
AGENT_PORT=8002

# ── CKAN ──
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
CKAN_HTTP_TIMEOUT=30

# ── LLM provider ──
# Valori supportati:
#   ollama        → modello locale via Ollama (default, nessuna API key richiesta)
#                   Imposta OLLAMA_BASE_URL e OLLAMA_LLM_MODEL qui sotto.
#   azure_foundry → Azure AI Foundry Agent Service, autenticato via Entra ID (DefaultAzureCredential)
#                   Richiede AZURE_AI_PROJECT_ENDPOINT e AZURE_AI_MODEL_DEPLOYMENT_NAME.
#   claude        → Anthropic Claude API
#                   Richiede ANTHROPIC_API_KEY; modello configurabile con CLAUDE_MODEL.
LLM_PROVIDER=ollama

# ── Ollama ──
# OLLAMA_IMAGE: immagine Docker con il modello già incluso (pubblicata su ghcr.io).
#   - default: ghcr.io/hevolus/ckan-mcp-ollama:latest  (pronta all'uso, ~7 GB)
#   - fallback build locale: OLLAMA_IMAGE=ollama/ollama:latest + make pull-models
OLLAMA_IMAGE=ghcr.io/hevolus/ckan-mcp-ollama:latest
OLLAMA_BASE_URL=http://ckan-ollama:11434
OLLAMA_LLM_MODEL=llama3.1:16k
OLLAMA_NUM_CTX=16384

# ── MCP server URL the agent container dials (compose-internal) ──
MCP_SERVER_URL=http://ckan-mcp:8080/mcp

# ── Misc ──
LOG_LEVEL=INFO

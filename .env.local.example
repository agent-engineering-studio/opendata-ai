# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
#  Local debug вЂ” copy to `.env` (or `.env.local`) before `make up`.
#
#  Default provider: ollama (no API key, runs on your machine).
#  Optional: switch to claude for fast iteration via Anthropic API
#  (set LLM_PROVIDER=claude + ANTHROPIC_API_KEY in the Claude section).
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# в”Ђв”Ђ Ports exposed on the host в”Ђв”Ђ
# Container-internal ports are unchanged; host-side bindings sit in a
# non-default range so they don't clash with locally-running Redis/Postgres/etc.
OLLAMA_PORT=11435
CKAN_MCP_PORT=18080
ISTAT_MCP_PORT=18081
OPENCOESIONE_MCP_PORT=18082 # OpenCoesione (progetti politiche di coesione)
OSM_MCP_PORT=18085          # OSM map renderer (Leaflet+OSM HTML for GeoJSON)
SOCRATA_MCP_PORT=18084      # Socrata (Discovery/Views/SODA APIs), standalone вЂ” non ancora nel fan-out
MATURITY_MCP_PORT=18087     # Maturity assessment (ODM 2025) over CKAN
BACKEND_PORT=18000          # unified backend вЂ” UI hits this
UI_PORT=13000               # Next.js static export served by nginx

# в”Ђв”Ђ Data sources в”Ђв”Ђ
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
CKAN_HTTP_TIMEOUT=30
ISTAT_SDMX_BASE_URL=https://esploradati.istat.it/SDMXWS/rest
ISTAT_HTTP_TIMEOUT=60
OPENCOESIONE_BASE_URL=https://opencoesione.gov.it/it/api
OPENCOESIONE_HTTP_TIMEOUT=60

# Optional SDMX sources вЂ” OFF in local debug to keep iteration fast and cheap.
# Each one adds 1 specialist LLM call per query.
EUROSTAT_SDMX_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination/sdmx/2.1
ENABLE_EUROSTAT=false
OECD_SDMX_BASE_URL=https://sdmx.oecd.org/public/rest
ENABLE_OECD=false

# OpenCoesione (progetti finanziati dalle politiche di coesione) вЂ” evidenza
# finanziaria, la fonte CUORE della pagina /territorio: senza, la scheda
# programmatica esce vuota (i guardrail scartano i claim senza fonte).
# Aggiunge 1 chiamata LLM (specialista) per query.
ENABLE_OPENCOESIONE=true
OPENCOESIONE_AGENT_NAME=opencoesione
# Mirror locale del bulk (CC BY 4.0) per gli aggregati pesanti: popolato da
# `make oc-sync` (CLI opendata-opencoesione-sync, usa DATABASE_URL), letto
# read-only dal tool opencoesione_query_local. Vuoto = tool disattivato.
# Dentro compose: OPENCOESIONE_DB_URL=postgresql://opendata:opendata@postgres:5432/opendata
OPENCOESIONE_DB_URL=

# Ambito territoriale (province ISTAT ammesse, comma-separated). Vuoto in dev;
# in produzione il verticale ГЁ SOLO Puglia: 071,072,073,074,075,110.
TERRITORIO_PROVINCE=

# OSM come specialista del fan-out (accessibilitГ : stazioni, servizi, distanze).
# Distinto da ENABLE_OSM_MAPS (render mappe deterministico, zero LLM):
# questo aggiunge 1 chiamata LLM per query. Riusa OSM_MCP_URL.
ENABLE_OSM=false
OSM_AGENT_NAME=osm

# Overpass (OSM) endpoint usato da backend + osm-mcp. I default upstream
# (overpass-api.de + kumi.systems) sono bloccati da alcune reti
# (ConnectError/timeout): usiamo i mirror FR (primario) + CH (fallback).
OVERPASS_URL=https://overpass.openstreetmap.fr/api/interpreter
OVERPASS_FALLBACK_URLS=https://overpass.osm.ch/api/interpreter
# Istanza self-hosted: `make up-host-ollama` la include SEMPRE e punta i client
# all'istanza locale (default sotto), col fallback FR a coprire l'init iniziale.
# Per gli altri target ГЁ opt-in: `make up OVERPASS=1` (o `make overpass-up`),
# poi decommenta qui per puntare i client all'istanza locale.
# Init lungo + disco ~25-50 GB вЂ” vedi infra/overpass/README.md.
# OVERPASS_URL=http://overpass/api/interpreter
# OVERPASS_FALLBACK_URLS=https://overpass.openstreetmap.fr/api/interpreter
# OVERPASS_PORT=18086
# OVERPASS_PLANET_URL=https://download.geofabrik.de/europe/italy-latest.osm.pbf
# OVERPASS_DIFF_URL=https://download.geofabrik.de/europe/italy-updates/

# ISPRA IdroGEO (vincoli ambientali: pericolositГ  frane/alluvioni per comune).
ENABLE_ISPRA=false
ISPRA_MCP_PORT=18083
ISPRA_MCP_URL=http://ispra-mcp:8083/mcp
ISPRA_AGENT_NAME=ispra

# Knowledge Graph (repo knowledge-graph, deployment ESTERNO): evidenza
# documentale вЂ” delibere/PUG/bilanci ingeriti sotto il namespace
# comune-{cod_comune}. Il kg-mcp va esposto in streamable-http su /mcp.
ENABLE_KG=false
KG_MCP_URL=http://localhost:8087/mcp
KG_AGENT_NAME=kg
KG_NAMESPACE_PREFIX=comune-
# Base URL della UI del KG per i link citazione ({KG_UI_URL}/documents/{doc_id});
# vuoto = riferimento sintetico kg:// (tracciabile ma non navigabile).
KG_UI_URL=

# Always-on sources (you almost never want to disable these locally)
ENABLE_CKAN=true
ENABLE_ISTAT=true

# в”Ђв”Ђ OpenDataSoft в”Ђв”Ђ opt-in: aggiunge i portali ODS al fan-out di /esplora.
# Con ENABLE_ODS=true il backend dialoga con ods-mcp (avvialo: docker compose up ods-mcp).
ENABLE_ODS=false
ODS_MCP_URL=http://ods-mcp:8080/mcp
ODS_DEFAULT_BASE_URL=https://public.opendatasoft.com

# в”Ђв”Ђ Socrata (#98) в”Ђв”Ђ connettore MCP standalone (Discovery/Views/SODA API),
# non ancora nel fan-out del backend (wiring rimandato a issue successiva).
# Avvialo con: docker compose up socrata-mcp
SOCRATA_DEFAULT_BASE_URL=https://opendata.socrata.com

# в”Ђв”Ђ OSM maps в”Ђв”Ђ render Leaflet+OSM HTML for GeoJSON resources (no LLM cost)
OSM_MCP_URL=http://osm-mcp:8080/mcp
ENABLE_OSM_MAPS=true

# в”Ђв”Ђ LLM provider в”Ђв”Ђ
# "auto" (recommended, incl. production) resolves by credential presence, in
# priority order:
#   1. claude         в†’ if ANTHROPIC_API_KEY is set
#   2. azure_foundry  в†’ if AZURE_AI_PROJECT_ENDPOINT + deployment name are set
#   3. ollama_cloud   в†’ if OLLAMA_CLOUD_API_KEY is set (hosted, metered)
#   4. ollama         в†’ fallback (local self-hosted, no API key, free)
# Claude wins over Ollama Cloud when both keys are present. A user's own key
# (BYOK, set in their profile) overrides this entirely. With the local Ollama
# provider the LLM-access gate is open (no per-use cost); Claude / Ollama Cloud
# keep the paid gate (BYOK or subscription). Force a specific provider by
# setting it explicitly (ollama|ollama_cloud|claude|azure_foundry).
LLM_PROVIDER=auto

# в”Ђв”Ђ Ollama (used when auto falls back to local, or LLM_PROVIDER=ollama) в”Ђв”Ђ
# Pre-built image with qwen2.5:32k (num_ctx=16384, temperature 0) already baked in.
# Fallback: set OLLAMA_IMAGE=ollama/ollama:latest and run `make pull-models`.
OLLAMA_IMAGE=ghcr.io/agent-engineering-studio/opendata-ai-ollama:latest
OLLAMA_PULL_POLICY=if_not_present
# OLLAMA_BASE_URL points at the inference server. In Docker: opendata-ai-ollama.
# Host Ollama (macOS Metal): http://host.docker.internal:11434.
# Remote inference container in prod: set its URL here.
OLLAMA_BASE_URL=http://opendata-ai-ollama:11434
# Recommended on Apple Silicon (M4 Pro, 48GB) вЂ” strong tool-use + instruction
# following (avoids the weak-model failures: leaked "[вЂ¦]" template placeholders,
# wrong source in the lead). Just `ollama pull gpt-oss:20b` (no modelfile bake
# needed вЂ” large native context, runs fast at ~13GB). Alternatives:
# - qwen3:30b-a3b (MoE, smart+fast, ~20GB) 
# - qwen2.5:32b (same family, ~20GB)
# - qwen3.6:32b (MoE, smart+fast, ~20GB)
# - gemma4:30b (MoE, smart+fast, ~20GB) 
# - gpt-oss:20b (reasoning model, ~13GB)
OLLAMA_LLM_MODEL=qwen3.6:32b
OLLAMA_NUM_CTX=32768
# Greedy decoding (0) = max faithfulness to tool results, less hallucination.
# Note: gpt-oss is a reasoning model that officially prefers temperature ~1.0;
# raise this toward 1.0 if its output feels too terse or repetitive.
OLLAMA_TEMPERATURE=0

# в”Ђв”Ђ Anthropic Claude (active when LLM_PROVIDER=claude) в”Ђв”Ђ
# Get an API key at https://console.anthropic.com/settings/keys
# Set the key below (or run `make up-claude`, which requires it here).
# ANTHROPIC_API_KEY=sk-ant-...
# Default model. Options: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5.
CLAUDE_MODEL=claude-sonnet-4-6

# в”Ђв”Ђ Ollama Cloud (hosted) вЂ” system provider AND BYOK в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Get an API key at https://ollama.com (Account в†’ API keys).
# Set OLLAMA_CLOUD_API_KEY to use Ollama Cloud as the SYSTEM provider: picked by
# `LLM_PROVIDER=auto` when no ANTHROPIC_API_KEY is present, or forced with
# `make up-ollama-cloud` (which requires this key to be set here). Leave empty в†’
# ollama_cloud stays BYOK-only (users bring their own key from the profile).
# OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# в”Ђв”Ђ BYOK (bring your own key) вЂ” users' own Claude/Ollama key в”Ђв”Ђв”Ђв”Ђв”Ђ
# Fernet key to encrypt stored user keys: `opendata-byok-keygen`. Optional in
# dev (AUTH_ENABLED=false bypasses the access gate), required to test
# /account/llm-key end-to-end.
# BYOK_ENCRYPTION_KEY=

# в”Ђв”Ђ MCP server URLs в”Ђв”Ђ
# Docker compose: keep the internal hostnames below.
# Host-side debug (LLM_PROVIDER=claude, no Docker for the agents): change to
#   CKAN_MCP_URL=http://localhost:8080/mcp
#   ISTAT_MCP_URL=http://localhost:8081/mcp
#   OPENCOESIONE_MCP_URL=http://localhost:8084/mcp
CKAN_MCP_URL=http://ckan-mcp:8080/mcp
ISTAT_MCP_URL=http://istat-mcp:8081/mcp
OPENCOESIONE_MCP_URL=http://opencoesione-mcp:8082/mcp
OSM_MCP_URL=http://osm-mcp:8080/mcp
# maturity-mcp ГЁ per host MCP esterni (Claude Desktop): il backend usa la libreria
# opendata_core.maturity in-process, quindi NON dial-a questo URL a runtime.
MATURITY_MCP_URL=http://maturity-mcp:8080/mcp

# в”Ђв”Ђ Postgres (used by /me/*, /api-keys/*, /datasets/classify) в”Ђв”Ђ
POSTGRES_USER=opendata
POSTGRES_PASSWORD=opendata
POSTGRES_DB=opendata
POSTGRES_PORT=15432
# When running the backend as a host-side Python process, change `postgres` to `localhost`.
DATABASE_URL=postgresql+asyncpg://opendata:opendata@postgres:5432/opendata

# в”Ђв”Ђ Redis (cache for /datasets/fetch, /datasets/classify, /datasets/by-category + rate-limit) в”Ђв”Ђ
REDIS_PORT=16379
REDIS_URL=redis://redis:6379/1
# Baseline requests/minute per user (the "free" tier). Set to 0 to disable.
RATE_LIMIT_PER_MINUTE=60
# Per-subscription-tier overrides as `tier=limit` (comma-separated). A tier not
# listed вЂ” including "free" вЂ” falls back to the baseline above. Names must match
# the user's `subscription_tier`; until plans are assigned everyone is "free",
# so these values stay inert. Use a large number (not 0) for an "unlimited" tier
# вЂ” 0 disables the limiter entirely for that tier.
RATE_LIMIT_TIERS=pro=300,enterprise=1200

# в”Ђв”Ђ Frontend в†’ backend wiring (used by the Next.js bundle) в”Ђв”Ђ
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# в”Ђв”Ђ Backend CORS вЂ” comma-separated list of allowed origins в”Ђв”Ђ
# `:13000` = nginx-served static export (compose). `:3000` = host-side `npm run dev`.
CORS_ALLOW_ORIGINS=http://localhost:13000,http://localhost:3000

# в”Ђв”Ђ A2A protocol (Agent-to-Agent) в”Ђв”Ђ
# When enabled, the backend publishes /.well-known/agent.json and exposes
# JSON-RPC at /a2a/. `a2a_public_url` is baked into the AgentCard so other
# agents know where to call us вЂ” set it to the externally-reachable URL.
A2A_ENABLED=true
A2A_PUBLIC_URL=http://localhost:18000
# Outbound (Phase 3 / Import): when set, a remote A2A agent is added to the
# orchestrator fan-out as a peer specialist. Leave empty to disable.
# A2A_SPECIALIST_URL=http://localhost:18000   # self-reference for round-trip demo
# A2A_SPECIALIST_BEARER=
# A2A_SPECIALIST_NAME=external

# в”Ђв”Ђ Clerk auth (OFF locally for fast iteration; ON in production) в”Ђв”Ђ
# Clerk app: app_3EMALiLi0UTULl89JPMKtaLENoy вЂ” see .clerk/config.md for the
# full setup procedure (`clerk init --app app_3EMALiLi0UTULl89JPMKtaLENoy`).
# When AUTH_ENABLED=false the backend bypasses JWT verification and treats
# every request as a synthetic dev user вЂ” there is no fallback to anonymous,
# so keep this honest. Flip to `true` and fill the keys below to exercise
# the real flow locally.
AUTH_ENABLED=false
# Frontend bundle key вЂ” surfaced to the Next.js app, not used by the backend.
# CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Backend secret вЂ” only needed to call Clerk's Backend API (out of webhook flow).
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
# JWT issuer вЂ” find it at Dashboard в†’ API Keys в†’ Show JWT public key (issuer).
# CLERK_JWT_ISSUER=https://<your-app>.clerk.accounts.dev
# Endpoint signing secret вЂ” Dashboard в†’ Webhooks в†’ Endpoint в†’ Signing Secret.
# CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx

# в”Ђв”Ђ Stripe contributi (pagina /sostieni) в”Ђв”Ђ
# Per i test locali: `stripe listen --forward-to localhost:8000/webhooks/stripe`
# stampa un signing secret whsec_вЂ¦ da incollare qui.
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_API_KEY=rk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Mappa priceв†’tier (usa i price id di TEST in locale):
# STRIPE_PRICE_TIERS=price_xxx=sostenitore,price_yyy=pro,price_zzz=team

# в”Ђв”Ђ Monitoraggio schedulato (opendata-monitor, #88) в”Ђв”Ђ
# La notifica email ГЁ OUTWARD-FACING, quindi opt-in esplicito: senza SMTP_HOST
# configurato l'invio ГЁ saltato (loggato, mai un errore che blocca il run).
# Il webhook non ha bisogno di config qui: l'URL si imposta per singolo target
# in opendata.monitor_targets.webhook_url.
# SMTP_HOST=smtp.example.it
# SMTP_PORT=587
# SMTP_USER=notifiche@example.it
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# SMTP_FROM=notifiche@example.it

# в”Ђв”Ђ Misc в”Ђв”Ђ
LOG_LEVEL=INFO

SDMX_PERSISTENT_CACHE_TTL_SECONDS=86400   # 24h default (alza per cataloghi piГ№ stabili)
SDMX_PERSISTENT_CACHE_DIR=/var/cache/sdmx # path nel container; "" per disabilitare

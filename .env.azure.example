# ─────────────────────────────────────────────────────────────────
#  Azure deploy (.env.azure) — inputs for infra/scripts/deploy.*
#  Copy to .env.azure (gitignored) and fill.
# ─────────────────────────────────────────────────────────────────

# Target subscription + resource group
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-ckan-mcp-dev
AZURE_LOCATION=westeurope
AZURE_ENV_NAME=dev

# Azure Container Registry (must be globally unique, lowercase, 5-50 chars)
ACR_NAME=ckanmcpdev

# Azure OpenAI backing the agent in cloud
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Agent defaults
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
LLM_PROVIDER=azure_openai

# GitHub OIDC federation (only needed for `setup-github-oidc.sh`)
GITHUB_ORG=agent-engineering-studio
GITHUB_REPO=mcp-ckan

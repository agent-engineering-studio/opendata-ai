# ─────────────────────────────────────────────────────────────────
#  Deploy to Azure Container Apps.
#  Inputs for infra/scripts/deploy.{sh,ps1}.
#
#  Copy to .env.azure (gitignored) and fill.
# ─────────────────────────────────────────────────────────────────

# Target subscription + resource group
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-ckan-mcp-dev
AZURE_LOCATION=westeurope
AZURE_ENV_NAME=dev

# Azure Container Registry (must be globally unique, lowercase, 5-50 chars)
ACR_NAME=ckanmcpdev

# Azure AI Foundry project backing the agent in cloud
# - Endpoint format: https://<hub>.services.ai.azure.com/api/projects/<project>
# - Resource ID format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<hub>/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<hub>/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5

# Agent defaults
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
LLM_PROVIDER=azure_foundry

# GitHub OIDC federation (only needed for `setup-github-oidc.sh`)
GITHUB_ORG=agent-engineering-studio
GITHUB_REPO=mcp-ckan

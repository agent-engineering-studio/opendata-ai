# ─────────────────────────────────────────────────────────────────
#  Dev debug local against Anthropic Claude API.
#
#  • No docker container: MCP server and agent run as debugged Python
#    processes on the host (VSCode → "Stack debug — Claude").
#  • Authentication: plain API key from https://console.anthropic.com
#
#  Copy to .env.dev-claude before first use.
# ─────────────────────────────────────────────────────────────────

# ── Ports exposed on the host ──
MCP_PORT=8080
AGENT_PORT=8002

# ── LLM provider ──
LLM_PROVIDER=claude

# ── Anthropic Claude API ──
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model name — see https://docs.anthropic.com/en/docs/about-claude/models
# Latest recommended model:
CLAUDE_MODEL=claude-sonnet-4-6

# ── MCP server URL the agent will dial (localhost during debug) ──
MCP_SERVER_URL=http://localhost:8080/mcp

# ── CKAN ──
CKAN_DEFAULT_BASE_URL=https://www.dati.gov.it/opendata
CKAN_HTTP_TIMEOUT=30

# ── Misc ──
LOG_LEVEL=INFO
